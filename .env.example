NODE_ENV=test

# Backend Database
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_USER=easyrag
DATABASE_PASSWORD=changeme_strong_password
DATABASE_NAME=easyrag

# MCP Vector Database
MCP_DB_USER=mcp
MCP_DB_PASSWORD=changeme_mcp_password
MCP_DB_NAME=mcpdb

# JWT Secrets (generate with: openssl rand -base64 32)
JWT_SECRET=changeme_jwt_secret_min_32_chars
JWT_REFRESH_SECRET=changeme_refresh_secret_min_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Internal LLM (used for prompt generation + embeddings in rag-service)
# Supported values: openai, mistral
INTERNAL_LLM_PROVIDER=openai
# Provider API key for internal LLM calls
INTERNAL_LLM_API_KEY=
# Optional overrides (provider defaults are used when empty)
INTERNAL_EMBEDDING_MODEL=
SYSTEM_PROMPT_MODEL=

# Optional OpenAI fallback for backward compatibility
OPENAI_API_KEY=sk-your-openai-api-key

# Frontend URL for CORS
CLIENT_ORIGIN=https://your-domain.com

# Encryption key for API keys (generate with: openssl rand -base64 32)
ENCRYPTION_KEY=your-32-byte-base64-encryption-key

# Email verification settings (optional overrides)
EMAIL_VERIFICATION_TTL_MIN=15

# SMTP settings for transactional emails
SMTP_HOST=
SMTP_TLS_REJECT_UNAUTHORIZED=false
SMTP_PORT=
SMTP_SECURE=
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=

# Vector Database
PGVECTOR_USER=mcp
PGVECTOR_PASSWORD=changeme_mcp_password
PGVECTOR_HOST=mcp-vector-db
PGVECTOR_PORT=5432
PGVECTOR_DATABASE=mcpdb
