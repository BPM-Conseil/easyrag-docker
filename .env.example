# Backend Database
DATABASE_USER=easyrag
DATABASE_PASSWORD=changeme_strong_password
DATABASE_NAME=easyrag

# MCP Vector Database
MCP_DB_USER=mcp
MCP_DB_PASSWORD=changeme_mcp_password
MCP_DB_NAME=mcpdb

# JWT Secrets (generate with: openssl rand -base64 32)
JWT_SECRET=changeme_jwt_secret_min_32_chars
JWT_REFRESH_SECRET=changeme_refresh_secret_min_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# OpenAI API Key for embeddings
OPENAI_API_KEY=sk-your-openai-api-key

# Frontend URL for CORS
CLIENT_ORIGIN=https://your-domain.com

# Encryption key for API keys (generate with: openssl rand -base64 32)
ENCRYPTION_KEY=your-32-byte-base64-encryption-key

# License Configuration
# Public key for verifying license signatures (Base64 encoded Ed25519 public key)
LICENSE_PUBLIC_KEY=
# Optional: License key as environment variable
LICENSE_KEY=
# Optional: Path to license file (default: /data/license.key)
LICENSE_FILE_PATH=/data/license.key
# License validation service URL (your vendor server)
LICENSE_VALIDATION_URL=https://license.your-domain.com
# License service URL for admin operations (issue/revoke)
LICENSE_SERVICE_URL=https://license.your-domain.com
# Hours between validation checks (default: 24)
LICENSE_VALIDATION_INTERVAL_HOURS=24
# Days allowed offline before downgrade to free tier (default: 7)
LICENSE_OFFLINE_GRACE_DAYS=7

# Internal Token Configuration (for Node.js -> Python service communication)
# Ed25519 private key for signing internal tokens (Base64 encoded)
NODE_INTERNAL_TOKEN_PRIVATE_KEY=
# Ed25519 public key for verifying internal tokens in Python service (Base64 encoded)
INTERNAL_TOKEN_PUBLIC_KEY=
