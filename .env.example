NODE_ENV=test

# Backend Database
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_USER=easyrag
DATABASE_PASSWORD=changeme_strong_password
DATABASE_NAME=easyrag

# MCP Vector Database
MCP_DB_USER=mcp
MCP_DB_PASSWORD=changeme_mcp_password
MCP_DB_NAME=mcpdb

# JWT Secrets (generate with: openssl rand -base64 32)
JWT_SECRET=changeme_jwt_secret_min_32_chars
JWT_REFRESH_SECRET=changeme_refresh_secret_min_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Internal LLM (used for prompt generation + embeddings in rag-service)
# Supported values: openai, mistral
INTERNAL_LLM_PROVIDER=openai
# Provider API key for internal LLM calls
INTERNAL_LLM_API_KEY=
# Optional overrides (provider defaults are used when empty)
INTERNAL_EMBEDDING_MODEL=
SYSTEM_PROMPT_MODEL=

# Warning: embeddings from different providers/models/dimensions are not directly compatible.
# If you change INTERNAL_EMBEDDING_MODEL or EMBEDDING_DIMENSION, reindex your corpora.

# Optional public credential available to all users
# When PUBLIC_LLM_API_KEY is set, a synthetic credential appears for every user.
PUBLIC_LLM_API_KEY=
# Supported values: openai, anthropic, mistral, gemini
PUBLIC_LLM_PROVIDER=openai
PUBLIC_LLM_NAME=Public API key
# Per-user daily cap when using the public credential
PUBLIC_LLM_DAILY_MESSAGE_LIMIT=20

# Frontend URL for CORS
CLIENT_ORIGIN=https://your-domain.com

# Enable landing page (set to YES to enable) - Connexion page otherwise
LANDING_PAGE_ENABLED=YES

# Encryption key for API keys (generate with: openssl rand -base64 32)
ENCRYPTION_KEY=your-32-byte-base64-encryption-key

# Email verification settings (optional overrides)
EMAIL_VERIFICATION_TTL_MIN=15

# SMTP settings for transactional emails (needed for user registration code verification)
SMTP_HOST=
SMTP_TLS_REJECT_UNAUTHORIZED=false
SMTP_PORT=
SMTP_SECURE=
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=

# Vector Database
PGVECTOR_USER=mcp
PGVECTOR_PASSWORD=changeme_mcp_password
PGVECTOR_HOST=mcp-vector-db
PGVECTOR_PORT=5432
PGVECTOR_DATABASE=mcpdb
