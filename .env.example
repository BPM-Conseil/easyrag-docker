NODE_ENV=test

# Backend Database
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_USER=easyrag
DATABASE_PASSWORD=changeme_strong_password
DATABASE_NAME=easyrag

# JWT Secrets (generate with: openssl rand -base64 32)
JWT_SECRET=changeme_jwt_secret_min_32_chars
JWT_REFRESH_SECRET=changeme_refresh_secret_min_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Internal LLM (used for prompt generation + embeddings in rag-service)
# Supported values: openai, mistral
INTERNAL_LLM_PROVIDER=openai
# Set this key to the provider API key (Mistral or OpenAI)
INTERNAL_LLM_API_KEY=
# Optional overrides (provider defaults are used when empty)
INTERNAL_EMBEDDING_MODEL=
SYSTEM_PROMPT_MODEL=

# Optional API key for Serper web search tool (used when chatbot web search is enabled)
SERPER_API_KEY=

# Warning: embeddings from different providers/models/dimensions are not directly compatible.
# If you change INTERNAL_EMBEDDING_MODEL or EMBEDDING_DIMENSION, reindex your corpora.

# Optional Public LLM Configuration to give a default credential to every users
# When PUBLIC_LLM_API_KEY is set, a synthetic credential appears for every user.
PUBLIC_LLM_API_KEY=
# Supported values: openai, anthropic, mistral, gemini
PUBLIC_LLM_PROVIDER=openai
PUBLIC_LLM_NAME=Public API key
# Per-user daily cap when using the public credential
PUBLIC_LLM_DAILY_MESSAGE_LIMIT=20

# Frontend URL(s) for CORS (comma separated)
CLIENT_ORIGIN=https://chat.your-domain.com,https://platform.your-domain.com
API_BASE_URL=http://localhost:3000

# Shared auth cookie options for chat/platform subdomains
AUTH_COOKIE_DOMAIN=.your-domain.com
AUTH_COOKIE_SAMESITE=lax

# Enable landing page (set to YES to enable) - Connexion page otherwise
LANDING_PAGE_ENABLED=YES

# URL opened by the "Platform" button from chat hub
PLATFORM_BASE_URL=https://platform.your-domain.com

# Fallback chat when user is unauthenticated or has no linked chatbot
CHAT_FALLBACK_ENABLED=YES
CHAT_FALLBACK_DAILY_LIMIT=3

CORPUS_UPLOAD_MAX_FILE_MB=200
CORPUS_UPLOAD_MAX_FILES=20

CHAT_HISTORY_MAX_MESSAGES=50

# Encryption key for API keys (generate with: openssl rand -base64 32)
ENCRYPTION_KEY=your-32-byte-base64-encryption-key

# Email verification settings (optional overrides)
EMAIL_VERIFICATION_TTL_MIN=15

# SMTP settings for transactional emails (needed for user registration code verification)
SMTP_HOST=
SMTP_TLS_REJECT_UNAUTHORIZED=false
SMTP_PORT=
SMTP_SECURE=
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=

# Redis (used for BullMQ job queues and rate limiting)
REDIS_HOST=redis
REDIS_PORT=6379
# REDIS_URL=redis://redis:6379  # Uncomment to use a full URL instead of host/port

# Internal token for backend → rag-service authentication (optional)
# This property can be used if the rag-service is exposed on a public URL and you want to restrict access to it. Generate a keypair with: openssl genpkey -algorithm ed25519 | tee private.pem && openssl pkey -in private.pem -pubout
# Generate keypair with: openssl genpkey -algorithm ed25519 | tee private.pem && openssl pkey -in private.pem -pubout
# NODE_INTERNAL_TOKEN_PRIVATE_KEY=
# INTERNAL_TOKEN_PUBLIC_KEY=

# Vector Database
PGVECTOR_USER=mcp
PGVECTOR_PASSWORD=changeme_mcp_password
PGVECTOR_HOST=mcp-vector-db
PGVECTOR_PORT=5432
PGVECTOR_DATABASE=mcpdb

# MCP server database & credentials
MCP_DB_USER=mcp
MCP_DB_PASSWORD=changeme_mcp_password
MCP_DB_NAME=mcpdb